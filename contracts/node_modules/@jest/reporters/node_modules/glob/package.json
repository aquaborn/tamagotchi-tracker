// Handle menu selection
async function handleMenuSelection(chatId, user, text) {
    if (!bot)
        return;
    if (text?.includes('Общий чат')) {
        await joinRoom(chatId, user, 'general');
    }
    else if (text?.includes('Пошлый чат')) {
        const hasSubscription = await checkSubscription(user.id);
        if (hasSubscription) {
            await joinRoom(chatId, user, 'adult');
        }
        else {
            await offerSubscription(chatId, user.id);
        }
    }
    else {
        await bot.sendMessage(chatId, 'Выберите чат из меню');
    }
}
