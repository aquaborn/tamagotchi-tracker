// Handle promo visit
async function handlePromoVisit(telegramId, promoCode) {
    try {
        const promo = await (0, shared_1.queryOne)('SELECT id FROM promo_codes WHERE code = $1', [promoCode]);
        if (promo) {
            await (0, shared_1.query)('INSERT INTO promo_visits (promo_code_id, telegram_id, first_seen_at) VALUES ($1, $2, NOW())', [promo.id, telegramId]);
        }
    }
    catch (error) {
        console.error('Error handling promo visit:', error);
    }
}
