// Broadcast to room
async function broadcastToRoom(room, messageData, excludeChatId) {
    if (!bot)
        return;
    try {
        const response = await fetch(`${chatServiceUrl}/api/rooms/online`);
        const data = await response.json();
        if (!data.success)
            return;
        const roomData = room === 'general' ? data.data.general : data.data.adult;
        const users = roomData.users || [];
        const userIds = users.filter((u) => u.id !== messageData.user_id).map((u) => u.id);
        if (userIds.length === 0)
            return;
        const telegramIds = await (0, shared_1.query)('SELECT telegram_id FROM users WHERE id = ANY($1)', [userIds]);
        for (const user of telegramIds) {
            if (excludeChatId && user.telegram_id === excludeChatId)
                continue;
            await sendMessageToChat(user.telegram_id, messageData, room);
        }
    }
    catch (error) {
        console.error('Error broadcasting to room:', error);
    }
}
